@page
@model BadFindPageModel
@{
    ViewData["Title"] = "Bad find page";
}

<main id="main-content" role="main">
    <div class="govuk-width-container govuk-main-wrapper govuk-!-padding-top-0">
        <div class="govuk-grid-row govuk-!-margin-top-7 tl-fap-home--container">
            <div class="govuk-grid-column-two-thirds">
                <div class="tl-card--grey">
                    <h1 class="govuk-heading-l govuk-!-margin-top-2 govuk-!-margin-bottom-7">Find a T Level school or college</h1>
                    <p class="govuk-body">No find ui - will we get js errors?</p>
                </div>
            </div>
            <div class="govuk-grid-column-one-third">
                <span class="tl-fap-home--image"></span>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script src="~/js/findProvider.js" 
            data-findProviderApiUri="{{ settings.find_provider_api_uri }}"
            data-findProviderAppId="{{ settings.find_provider_api_app_id }}"
            data-findProviderApiKey="{{ settings.find_provider_api_api_key }}"
            asp-append-version="true"></script>
}
